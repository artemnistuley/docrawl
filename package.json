{
  "name": "docrawl",
  "version": "0.1.0",
  "description": "Lightweight CLI for crawling documentation sites into Markdown with defuddle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artemnistuley/docrawl.git"
  },
  "type": "module",
  "bin": {
    "docrawl": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "npm run build && node --test test/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "15.0.0",
    "defuddle": "0.18.1",
    "fast-xml-parser": "5.8.0",
    "linkedom": "0.18.12",
    "p-limit": "7.3.0",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/picomatch": "4.0.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
